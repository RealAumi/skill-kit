{
  "name": "skill-kit",
  "version": "0.1.0",
  "description": "A forkable template for building Claude Code skill frameworks",
  "type": "module",
  "scripts": {
    "gen:skill-docs": "bun run scripts/gen-skill-docs.ts",
    "gen:skill-docs:dry": "bun run scripts/gen-skill-docs.ts --dry-run",
    "gen:skill-docs:codex": "bun run scripts/gen-skill-docs.ts --host codex",
    "gen:skill-docs:dry:codex": "bun run scripts/gen-skill-docs.ts --host codex --dry-run",
    "skill:check": "bun run scripts/skill-check.ts",
    "test": "bun test",
    "analytics": "bin/sk-analytics"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "license": "MIT"
}
