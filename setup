#!/usr/bin/env bash
# skill-kit setup — generate skills and register them with Claude Code / Codex.
#
# Usage:
#   ./setup                  # Install for Claude Code (default)
#   ./setup --host codex     # Install for Codex CLI
#   ./setup --host auto      # Auto-detect installed agents
#   ./setup --local          # Project-scoped install
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_DIR="$(cd "$(dirname "$0")" && pwd -P)"
FRAMEWORK_NAME="skill-kit"
CODEX_SKILLS="$HOME/.codex/skills"
CODEX_RUNTIME="$CODEX_SKILLS/$FRAMEWORK_NAME"
AGENTS_DIR="$SOURCE_DIR/.agents/skills"
ORIGIN_URL_FILE="$SOURCE_DIR/.skill-kit-origin-url"
ORIGIN_BRANCH_FILE="$SOURCE_DIR/.skill-kit-origin-branch"

HOST="claude"
LOCAL=false

while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      HOST="$2"; shift 2
      ;;
    --host=*)
      HOST="${1#*=}"; shift
      ;;
    --local)
      LOCAL=true; shift
      ;;
    -h|--help)
      echo "Usage: ./setup [--host claude|codex|auto] [--local]"
      echo ""
      echo "Options:"
      echo "  --host claude   Install for Claude Code (default)"
      echo "  --host codex    Install for Codex CLI"
      echo "  --host auto     Auto-detect installed agents"
      echo "  --local         Project-scoped install"
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

if [ "$HOST" = "auto" ]; then
  if command -v claude >/dev/null 2>&1; then
    HOST="claude"
  elif command -v codex >/dev/null 2>&1; then
    HOST="codex"
  else
    HOST="claude"
  fi
fi

echo ""
echo "  $FRAMEWORK_NAME setup (host: $HOST, $([ "$LOCAL" = true ] && echo 'local' || echo 'global'))"
echo ""

if ! command -v bun >/dev/null 2>&1; then
  echo "  ✗  Bun not found. Install: https://bun.sh"
  exit 1
fi
echo "  ✓  Bun $(bun --version)"

cd "$SOURCE_DIR"
if [ ! -d node_modules ] || [ package.json -nt node_modules/.package-lock.json 2>/dev/null ]; then
  bun install --frozen-lockfile 2>/dev/null || bun install
  echo "  ✓  Dependencies installed"
else
  echo "  ✓  Dependencies up to date"
fi

detect_origin_url() {
  git -C "$SOURCE_DIR" remote get-url origin 2>/dev/null || true
}

detect_origin_branch() {
  local branch
  branch="$(git -C "$SOURCE_DIR" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')"
  [ -n "$branch" ] || branch="$(git -C "$SOURCE_DIR" remote show origin 2>/dev/null | awk '/HEAD branch/ {print $NF}')"
  [ -n "$branch" ] || branch="main"
  echo "$branch"
}

persist_origin_metadata() {
  local origin_url origin_branch
  origin_url="$(detect_origin_url)"
  [ -n "$origin_url" ] || return 0
  origin_branch="$(detect_origin_branch)"
  printf '%s\n' "$origin_url" > "$ORIGIN_URL_FILE"
  printf '%s\n' "$origin_branch" > "$ORIGIN_BRANCH_FILE"
}

generate_docs() {
  local host="$1"
  bun run gen:skill-docs --host "$host" 2>&1 | while IFS= read -r line; do
    echo "  $line"
  done
}

link_claude_skill_dirs() {
  local skills_dir="$1"
  local linked=0
  mkdir -p "$skills_dir"

  local framework_link="$skills_dir/$FRAMEWORK_NAME"
  [ -L "$framework_link" ] && rm -f "$framework_link"
  ln -snf "$SOURCE_DIR" "$framework_link"
  echo "  ✓  Linked $FRAMEWORK_NAME → $SOURCE_DIR"

  for skill_dir in "$SOURCE_DIR"/skills/*/; do
    [ -f "$skill_dir/SKILL.md" ] || continue
    local skill_name link_path
    skill_name="$(basename "$skill_dir")"
    link_path="$skills_dir/$skill_name"
    [ -L "$link_path" ] && rm -f "$link_path"
    ln -snf "$skill_dir" "$link_path"
    linked=$((linked + 1))
  done

  echo "  ✓  Linked $linked skill(s) to $skills_dir/"
}

create_agents_sidecar() {
  local runtime_root="$AGENTS_DIR/$FRAMEWORK_NAME"
  mkdir -p "$runtime_root" "$runtime_root/upgrade"

  ln -snf "$SOURCE_DIR/bin" "$runtime_root/bin"
  ln -snf "$SOURCE_DIR/VERSION" "$runtime_root/VERSION"

  if [ -f "$AGENTS_DIR/upgrade/SKILL.md" ]; then
    ln -snf "$AGENTS_DIR/upgrade/SKILL.md" "$runtime_root/upgrade/SKILL.md"
  fi
}

create_codex_runtime_root() {
  local runtime_root="$1"

  if [ -L "$runtime_root" ]; then
    rm -f "$runtime_root"
  elif [ -d "$runtime_root" ]; then
    rm -rf "$runtime_root"
  fi

  mkdir -p "$runtime_root" "$runtime_root/upgrade"
  ln -snf "$SOURCE_DIR/bin" "$runtime_root/bin"
  ln -snf "$SOURCE_DIR/VERSION" "$runtime_root/VERSION"

  if [ -f "$AGENTS_DIR/upgrade/SKILL.md" ]; then
    ln -snf "$AGENTS_DIR/upgrade/SKILL.md" "$runtime_root/upgrade/SKILL.md"
  fi
}

link_codex_skill_dirs() {
  local skills_dir="$1"
  local linked=0
  mkdir -p "$skills_dir"

  for skill_dir in "$AGENTS_DIR"/*/; do
    [ -f "$skill_dir/SKILL.md" ] || continue
    local skill_name link_path
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "$FRAMEWORK_NAME" ] && continue
    link_path="$skills_dir/$skill_name"
    if [ -L "$link_path" ] || [ ! -e "$link_path" ]; then
      ln -snf "$skill_dir" "$link_path"
      linked=$((linked + 1))
    fi
  done

  echo "  ✓  Linked $linked Codex skill(s) to $skills_dir/"
}

persist_origin_metadata
generate_docs "$HOST"

STATE_DIR="$HOME/.skill-kit"
mkdir -p "$STATE_DIR/analytics" "$STATE_DIR/sessions"

if [ "$HOST" = "claude" ]; then
  if [ "$LOCAL" = true ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    TARGET_DIR="$REPO_ROOT/.claude/skills"
  else
    TARGET_DIR="$HOME/.claude/skills"
  fi

  link_claude_skill_dirs "$TARGET_DIR"
else
  create_agents_sidecar

  if [ "$LOCAL" = true ]; then
    echo "  ✓  Generated Codex artifacts in $AGENTS_DIR/"
    echo "  ✓  Runtime root ready at $AGENTS_DIR/$FRAMEWORK_NAME/"
  else
    mkdir -p "$CODEX_SKILLS"
    create_codex_runtime_root "$CODEX_RUNTIME"
    link_codex_skill_dirs "$CODEX_SKILLS"
    echo "  ✓  Runtime root ready at $CODEX_RUNTIME/"
  fi
fi

FIRST_RUN=false
if [ ! -f "$STATE_DIR/.setup-complete" ]; then
  FIRST_RUN=true
  touch "$STATE_DIR/.setup-complete"
fi

echo ""
if [ "$FIRST_RUN" = true ]; then
  echo "  ┌────────────────────────────────────────┐"
  echo "  │  Welcome to $FRAMEWORK_NAME!                  │"
  echo "  │                                        │"
  echo "  │  Your skills are ready. Try:           │"
  echo "  │    /hello  - a minimal example skill   │"
  echo "  │    /upgrade - upgrade the framework    │"
  echo "  │                                        │"
  echo "  │  Keep current anytime with:            │"
  echo "  │    bin/sk-upgrade                      │"
  echo "  │                                        │"
  echo "  │  Docs: CLAUDE.md & ARCHITECTURE.md     │"
  echo "  └────────────────────────────────────────┘"
else
  echo "  Setup complete."
fi
echo ""
