#!/usr/bin/env bash
# skill-kit setup — Install skills and create symlinks for Claude Code discovery.
#
# Usage:
#   ./setup                  # Install for Claude Code (default)
#   ./setup --host codex     # Install for Codex CLI
#   ./setup --host auto      # Auto-detect installed agents
#   ./setup --local          # Project-scoped install (repo-local)
#
# What this script does:
# 1. Parse arguments
# 2. Generate SKILL.md from templates (bun run gen:skill-docs)
# 3. Create symlinks in ~/.claude/skills/ for skill discovery
# 4. Create state directory (~/.skill-kit/)
# 5. Show welcome message
#
# Design: Skills are discovered by Claude Code via symlinks.
# Each skill directory (containing SKILL.md) gets its own symlink.
# This means changes in this repo are immediately visible to Claude.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FRAMEWORK_NAME="skill-kit"

# ── Parse arguments ──────────────────────────────────────────

HOST="claude"
LOCAL=false

while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      HOST="$2"; shift 2
      ;;
    --host=*)
      HOST="${1#*=}"; shift
      ;;
    --local)
      LOCAL=true; shift
      ;;
    -h|--help)
      echo "Usage: ./setup [--host claude|codex|auto] [--local]"
      echo ""
      echo "Options:"
      echo "  --host claude   Install for Claude Code (default)"
      echo "  --host codex    Install for Codex CLI"
      echo "  --host auto     Auto-detect installed agents"
      echo "  --local         Project-scoped install (repo-local)"
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Auto-detect host
if [ "$HOST" = "auto" ]; then
  if command -v claude >/dev/null 2>&1; then
    HOST="claude"
  elif command -v codex >/dev/null 2>&1; then
    HOST="codex"
  else
    echo "Error: No supported AI agent found (claude, codex)." >&2
    echo "Install Claude Code or Codex CLI first." >&2
    exit 1
  fi
fi

echo ""
echo "  $FRAMEWORK_NAME setup (host: $HOST, $([ "$LOCAL" = true ] && echo 'local' || echo 'global'))"
echo ""

# ── Step 1: Check Bun ────────────────────────────────────────

if ! command -v bun >/dev/null 2>&1; then
  echo "  ✗  Bun not found. Install: https://bun.sh"
  exit 1
fi
echo "  ✓  Bun $(bun --version)"

# ── Step 2: Install dependencies ─────────────────────────────

cd "$SCRIPT_DIR"
if [ ! -d node_modules ] || [ package.json -nt node_modules/.package-lock.json 2>/dev/null ]; then
  bun install --frozen-lockfile 2>/dev/null || bun install
  echo "  ✓  Dependencies installed"
else
  echo "  ✓  Dependencies up to date"
fi

# ── Step 3: Generate SKILL.md from templates ─────────────────

bun run gen:skill-docs --host "$HOST" 2>&1 | while IFS= read -r line; do
  echo "  $line"
done

# ── Step 4: Determine target directory ───────────────────────

if [ "$LOCAL" = true ]; then
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
  case "$HOST" in
    claude) TARGET_DIR="$REPO_ROOT/.claude/skills" ;;
    codex)  TARGET_DIR="$REPO_ROOT/.agents/skills" ;;
  esac
else
  case "$HOST" in
    claude) TARGET_DIR="$HOME/.claude/skills" ;;
    codex)  TARGET_DIR="$HOME/.codex/skills" ;;
  esac
fi

mkdir -p "$TARGET_DIR"

# ── Step 5: Create symlinks ─────────────────────────────────

# Link the framework root
FRAMEWORK_LINK="$TARGET_DIR/$FRAMEWORK_NAME"
if [ -L "$FRAMEWORK_LINK" ]; then
  rm "$FRAMEWORK_LINK"
fi
ln -sf "$SCRIPT_DIR" "$FRAMEWORK_LINK"
echo "  ✓  Linked $FRAMEWORK_NAME → $SCRIPT_DIR"

# Link each skill directory (containing SKILL.md)
LINKED=0
for SKILL_DIR in "$SCRIPT_DIR"/skills/*/; do
  [ -f "$SKILL_DIR/SKILL.md" ] || continue
  SKILL_NAME=$(basename "$SKILL_DIR")
  LINK_PATH="$TARGET_DIR/$SKILL_NAME"

  if [ -L "$LINK_PATH" ]; then
    rm "$LINK_PATH"
  fi
  ln -sf "$SKILL_DIR" "$LINK_PATH"
  LINKED=$((LINKED + 1))
done

echo "  ✓  Linked $LINKED skill(s) to $TARGET_DIR/"

# ── Step 6: Create state directory ───────────────────────────

STATE_DIR="$HOME/.skill-kit"
mkdir -p "$STATE_DIR/analytics" "$STATE_DIR/sessions"

# ── Step 7: Welcome message ──────────────────────────────────

FIRST_RUN=false
if [ ! -f "$STATE_DIR/.setup-complete" ]; then
  FIRST_RUN=true
  touch "$STATE_DIR/.setup-complete"
fi

echo ""
if [ "$FIRST_RUN" = true ]; then
  echo "  ┌────────────────────────────────────────┐"
  echo "  │  Welcome to $FRAMEWORK_NAME!                  │"
  echo "  │                                        │"
  echo "  │  Your skills are ready. Try:           │"
  echo "  │    /hello  — a minimal example skill   │"
  echo "  │                                        │"
  echo "  │  Add your own:                         │"
  echo "  │    1. Create skills/my-skill/          │"
  echo "  │    2. Add SKILL.md.tmpl                │"
  echo "  │    3. Run ./setup                      │"
  echo "  │                                        │"
  echo "  │  Docs: README.md & ARCHITECTURE.md     │"
  echo "  └────────────────────────────────────────┘"
else
  echo "  Setup complete. $LINKED skill(s) registered."
fi
echo ""
