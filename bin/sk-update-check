#!/usr/bin/env bash
# sk-update-check — periodic version check for all skills.
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>       — marker found from recent upgrade
#   UPGRADE_AVAILABLE <old> <new>   — remote VERSION differs from local
#   (nothing)                       — up to date, snoozed, disabled, or skipped
set -euo pipefail

SKILLKIT_DIR="${SKILLKIT_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
SOURCE_SKILLKIT_DIR="$(cd "$(dirname "$0")/.." && pwd -P)"
STATE_DIR="${SKILLKIT_STATE_DIR:-$HOME/.skill-kit}"
CACHE_FILE="$STATE_DIR/last-update-check"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
VERSION_FILE="$SKILLKIT_DIR/VERSION"
CONFIG_CMD="$SOURCE_SKILLKIT_DIR/bin/sk-config"
ORIGIN_URL_FILE="$SOURCE_SKILLKIT_DIR/.skill-kit-origin-url"
ORIGIN_BRANCH_FILE="$SOURCE_SKILLKIT_DIR/.skill-kit-origin-branch"

parse_repo_slug() {
  echo "$1" | sed -nE \
    -e 's#^git@github\.com:([^/]+/[^/.]+)(\.git)?$#\1#p' \
    -e 's#^https://github\.com/([^/]+/[^/.]+)(\.git)?$#\1#p' \
    | head -1
}

detect_origin_url() {
  git -C "$SOURCE_SKILLKIT_DIR" remote get-url origin 2>/dev/null || cat "$ORIGIN_URL_FILE" 2>/dev/null || true
}

detect_origin_branch() {
  local branch
  branch="$(git -C "$SOURCE_SKILLKIT_DIR" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')"
  [ -n "$branch" ] || branch="$(git -C "$SOURCE_SKILLKIT_DIR" remote show origin 2>/dev/null | awk '/HEAD branch/ {print $NF}')"
  [ -n "$branch" ] || branch="$(cat "$ORIGIN_BRANCH_FILE" 2>/dev/null || true)"
  [ -n "$branch" ] || branch="main"
  echo "$branch"
}

build_remote_url() {
  local origin_url repo_slug branch
  origin_url="$(detect_origin_url)"
  repo_slug="$(parse_repo_slug "$origin_url")"
  [ -n "$repo_slug" ] || return 1
  branch="$(detect_origin_branch)"
  printf 'https://raw.githubusercontent.com/%s/%s/VERSION\n' "$repo_slug" "$branch"
}

check_snooze() {
  local remote_ver="$1"
  [ -f "$SNOOZE_FILE" ] || return 1

  local snoozed_ver snoozed_level snoozed_epoch
  snoozed_ver="$(awk '{print $1}' "$SNOOZE_FILE" 2>/dev/null || true)"
  snoozed_level="$(awk '{print $2}' "$SNOOZE_FILE" 2>/dev/null || true)"
  snoozed_epoch="$(awk '{print $3}' "$SNOOZE_FILE" 2>/dev/null || true)"

  [ -n "$snoozed_ver" ] || return 1
  [ -n "$snoozed_level" ] || return 1
  [ -n "$snoozed_epoch" ] || return 1

  case "$snoozed_level" in *[!0-9]*) return 1 ;; esac
  case "$snoozed_epoch" in *[!0-9]*) return 1 ;; esac
  [ "$snoozed_ver" = "$remote_ver" ] || return 1

  local duration
  case "$snoozed_level" in
    1) duration=86400 ;;
    2) duration=172800 ;;
    *) duration=604800 ;;
  esac

  local now expires
  now="$(date +%s)"
  expires=$((snoozed_epoch + duration))
  [ "$now" -lt "$expires" ]
}

REMOTE_URL="${SKILLKIT_REMOTE_URL:-}"
[ -n "$REMOTE_URL" ] || REMOTE_URL="$(build_remote_url 2>/dev/null || true)"
[ -n "$REMOTE_URL" ] || exit 0

if [ "${1:-}" = "--force" ]; then
  rm -f "$CACHE_FILE" "$SNOOZE_FILE"
fi

mkdir -p "$STATE_DIR"

_UC="$("$CONFIG_CMD" get update_check 2>/dev/null || true)"
if [ "$_UC" = "false" ]; then
  exit 0
fi

LOCAL_VER="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]' || true)"
[ -n "$LOCAL_VER" ] || exit 0

if [ -f "$MARKER_FILE" ]; then
  OLD_VER="$(cat "$MARKER_FILE" 2>/dev/null | tr -d '[:space:]' || true)"
  rm -f "$MARKER_FILE" "$SNOOZE_FILE"
  printf 'UP_TO_DATE %s\n' "$LOCAL_VER" > "$CACHE_FILE"
  [ -n "$OLD_VER" ] && echo "JUST_UPGRADED $OLD_VER $LOCAL_VER"
  exit 0
fi

if [ -f "$CACHE_FILE" ]; then
  CACHED="$(cat "$CACHE_FILE" 2>/dev/null || true)"
  case "$CACHED" in
    UP_TO_DATE*) CACHE_TTL=60 ;;
    UPGRADE_AVAILABLE*) CACHE_TTL=720 ;;
    *) CACHE_TTL=0 ;;
  esac

  STALE="$(find "$CACHE_FILE" -mmin +"$CACHE_TTL" 2>/dev/null || true)"
  if [ -z "$STALE" ] && [ "$CACHE_TTL" -gt 0 ]; then
    case "$CACHED" in
      UP_TO_DATE*)
        CACHED_VER="$(echo "$CACHED" | awk '{print $2}')"
        [ "$CACHED_VER" = "$LOCAL_VER" ] && exit 0
        ;;
      UPGRADE_AVAILABLE*)
        CACHED_OLD="$(echo "$CACHED" | awk '{print $2}')"
        CACHED_NEW="$(echo "$CACHED" | awk '{print $3}')"
        if [ "$CACHED_OLD" = "$LOCAL_VER" ]; then
          check_snooze "$CACHED_NEW" && exit 0
          echo "$CACHED"
          exit 0
        fi
        ;;
    esac
  fi
fi

REMOTE_VER="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null | tr -d '[:space:]' || true)"
if ! echo "$REMOTE_VER" | grep -qE '^[0-9]+\.[0-9.]+$'; then
  printf 'UP_TO_DATE %s\n' "$LOCAL_VER" > "$CACHE_FILE"
  exit 0
fi

if [ "$LOCAL_VER" = "$REMOTE_VER" ]; then
  printf 'UP_TO_DATE %s\n' "$LOCAL_VER" > "$CACHE_FILE"
  exit 0
fi

printf 'UPGRADE_AVAILABLE %s %s\n' "$LOCAL_VER" "$REMOTE_VER" > "$CACHE_FILE"
check_snooze "$REMOTE_VER" && exit 0

echo "UPGRADE_AVAILABLE $LOCAL_VER $REMOTE_VER"
